# ==============================================================================
# Order Supervisor — Configuration
# ==============================================================================

# ── 1. Database ───────────────────────────────────────────────────────────────
# Default: PostgreSQL via docker-compose
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/order_supervisor

# Local fallback: SQLite, useful for quick UI-only demos
# DATABASE_URL=sqlite+aiosqlite:///./orders.db

# Production: PostgreSQL (Supabase / RDS / etc.)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/db_name


# ── 2. LLM Provider (Default: Ollama) ─────────────────────────────────────────
# The active AI provider. Switching requires no code changes.
# Valid options: ollama, gemini, openai, anthropic, groq, azure, bedrock, etc.
# See docs/LLM_PROVIDERS.md for the full list.
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b

# Optional: Override the base URL for OpenAI-compatible providers
# LLM_BASE_URL=http://localhost:11434

# Optional: Adjust the request timeout (seconds)
# LLM_TIMEOUT=60


# ── 3. API Keys (Uncomment and set for cloud providers) ───────────────────────

# Google Gemini (if LLM_PROVIDER=gemini)
# GEMINI_API_KEY=your_google_api_key

# OpenAI (if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Anthropic Claude (if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Groq (if LLM_PROVIDER=groq)
# GROQ_API_KEY=gsk_...

# Azure OpenAI (if LLM_PROVIDER=azure)
# AZURE_OPENAI_API_KEY=your_key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-02-01

# AWS Bedrock (if LLM_PROVIDER=bedrock)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1
